<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <TextView
        android:id="@+id/debugTitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Debug Log"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp" />

    <TextView
        android:id="@+id/debugStatusText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Connecting..."
        android:textColor="#AAAAAA"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/debugTitleText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- Mark Rep button — big and prominent -->
    <Button
        android:id="@+id/markRepButton"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="👆 Tap to mark START"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#34C759"
        android:stateListAnimator="@null"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/debugStatusText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:id="@+id/debugScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp"
        android:background="#0D0D1A"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/markRepButton"
        app:layout_constraintBottom_toTopOf="@id/pauseButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/logContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textColor="#EBEBF5"
            android:lineSpacingExtra="4dp"
            android:text="" />

    </ScrollView>

    <Button
        android:id="@+id/pauseButton"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:text="⏸ Pause"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:background="@drawable/button_blue"
        android:stateListAnimator="@null"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="4dp"
        app:layout_constraintBottom_toTopOf="@id/copyButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/showComparisonButton"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/showComparisonButton"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:text="📊 Compare"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:backgroundTint="#5E5CE6"
        android:stateListAnimator="@null"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toTopOf="@id/copyButton"
        app:layout_constraintStart_toEndOf="@id/pauseButton"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/copyButton"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:text="📋 Copy Log"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:background="@drawable/button_dark"
        android:stateListAnimator="@null"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="4dp"
        app:layout_constraintBottom_toTopOf="@id/clearButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/clearButton"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/clearButton"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:text="Clear Log"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:background="@drawable/button_dark"
        android:stateListAnimator="@null"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toTopOf="@id/debugBackButton"
        app:layout_constraintStart_toEndOf="@id/copyButton"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/debugBackButton"
        android:layout_width="200dp"
        android:layout_height="48dp"
        android:text="← Back to Monitor"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/button_blue"
        android:stateListAnimator="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp" />

</androidx.constraintlayout.widget.ConstraintLayout>