<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TinyML Recorder"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp" />

    <Button
        android:id="@+id/connectButton"
        android:layout_width="200dp"
        android:layout_height="48dp"
        android:text="Connect"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/button_blue"
        android:stateListAnimator="@null"
        app:layout_constraintTop_toBottomOf="@id/titleText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp" />

    <!-- Exercise name + sets side by side -->
    <TextView
        android:id="@+id/exerciseLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Exercise Name"
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/connectButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/setsLabel"
        android:layout_marginTop="28dp"
        android:layout_marginStart="32dp" />

    <TextView
        android:id="@+id/setsLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="# of 15s sets"
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/connectButton"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="40dp" />

    <EditText
        android:id="@+id/exerciseInput"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:hint="e.g. tricep"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:gravity="center"
        android:background="@drawable/input_background"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:inputType="text"
        android:layout_marginTop="6dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/exerciseLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/setsInput" />

    <EditText
        android:id="@+id/setsInput"
        android:layout_width="80dp"
        android:layout_height="52dp"
        android:hint="1"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:gravity="center"
        android:background="@drawable/input_background"
        android:inputType="number"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/setsLabel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/exerciseInput" />

    <Button
        android:id="@+id/startButton"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:text="REC"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:background="@drawable/button_red_circle"
        android:stateListAnimator="@null"
        app:layout_constraintTop_toBottomOf="@id/exerciseInput"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Press Connect to find watch"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:gravity="center"
        android:layout_marginTop="28dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/startButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/samplesText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#0A84FF"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/statusText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/monitorButton"
        android:layout_width="200dp"
        android:layout_height="48dp"
        android:text="Monitor Exercise"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/button_blue"
        android:stateListAnimator="@null"
        app:layout_constraintBottom_toTopOf="@id/shareButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/shareButton"
        android:layout_width="160dp"
        android:layout_height="44dp"
        android:text="Share Last CSV"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:background="@drawable/button_dark"
        android:stateListAnimator="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="32dp" />

</androidx.constraintlayout.widget.ConstraintLayout>