<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:fillViewport="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingBottom="20dp"
        android:paddingTop="4dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EXERCISE MONITOR"
            android:textColor="#888888"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:gravity="center"
            android:layout_marginBottom="6dp" />

        <!-- Exercise name -->
        <TextView
            android:id="@+id/exerciseText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#0A84FF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- Video — centered in FrameLayout -->
        <FrameLayout
            android:id="@+id/videoContainer"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <VideoView
                android:id="@+id/exerciseVideo"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center" />

        </FrameLayout>

        <!-- Reps + Set row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Reps card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/card_dark"
                android:gravity="center"
                android:padding="16dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:id="@+id/repLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="REPS"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/repText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="56sp"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="0.9" />

            </LinearLayout>

            <!-- Set card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/card_dark"
                android:gravity="center"
                android:padding="16dp"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SET"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/setText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="56sp"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="0.9" />

                <TextView
                    android:id="@+id/totalText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#0A84FF"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Speed + Coach card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_dark"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SPEED"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/speedText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COACH"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/coachText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="13sp"
                    android:textStyle="italic"
                    android:gravity="end" />

            </LinearLayout>

        </LinearLayout>

        <!-- Status bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_dark"
            android:padding="12dp"
            android:gravity="center"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/monitorStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connecting..."
                android:textColor="#555555"
                android:textSize="12sp"
                android:gravity="center" />

        </LinearLayout>

        <!-- Primary buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <Button
                android:id="@+id/statsButton"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="View Stats"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/button_blue"
                android:stateListAnimator="@null"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/debugButton"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="Debug Log"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/button_blue"
                android:stateListAnimator="@null"
                android:layout_marginStart="6dp" />

        </LinearLayout>

        <!-- Secondary buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/resetButton"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="Reset Stats"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:background="@drawable/button_dark"
                android:stateListAnimator="@null"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/backButton"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="← Back"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:background="@drawable/button_dark"
                android:stateListAnimator="@null"
                android:layout_marginStart="6dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>